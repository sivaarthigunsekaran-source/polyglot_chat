# MongoDB - Free Atlas cluster at https://cloud.mongodb.com (free forever tier)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/polyglot-chat

# JWT Secret - change this to any random string
JWT_SECRET=your_super_secret_jwt_key_change_this

# Gemini AI - FREE at https://aistudio.google.com/apikey (1500 req/day free)
# Leave blank to use MyMemory translation only (also free)
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

PORT=5000
